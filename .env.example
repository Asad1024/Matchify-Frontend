# Copy to .env.local and adjust. Never commit .env.local.

# Backend origin (optional if using Vite proxy to same host)
# VITE_API_URL=http://localhost:5000

# Google OAuth client ID (public)
# VITE_GOOGLE_CLIENT_ID=

# VITE_APP_LOGO_URL=

# AI Matchmaker curated-pick cooldown (ms). Set the same value as backend AI_MATCH_COOLDOWN_MS (default 2h = 7200000).
# VITE_AI_MATCH_COOLDOWN_MS=7200000
